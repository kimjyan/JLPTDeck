# JLPTDeck — local distribution secrets (Firebase App Distribution).
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Origin of each value:
#   FIREBASE_APP_ID      Firebase console → Project settings →
#                        Your apps → iOS app → App ID. Format:
#                        1:1234567890:ios:abcdef0123456789
#   FIREBASE_TESTER_GROUPS  Firebase console → App Distribution →
#                        Testers & Groups. Use the group `alias`, NOT
#                        the display name. Comma-separated allowed.
#   FIREBASE_TESTER_EMAILS  Alternative to groups — comma-separated
#                        emails. Leave blank if using groups.
#
# Authentication — pick ONE of these two:
#   GOOGLE_APPLICATION_CREDENTIALS  Path to service account JSON file
#                        with the `Firebase App Distribution Admin`
#                        role. Recommended for CI.
#   FIREBASE_TOKEN       Personal CLI token from `firebase login:ci`.
#                        Easier for local dev. Treat as a secret.

FIREBASE_APP_ID=1:000000000000:ios:0000000000000000000000
FIREBASE_TESTER_GROUPS=beta-testers
FIREBASE_TESTER_EMAILS=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json
# FIREBASE_TOKEN=

# Optional — release notes override (otherwise reads AppStore/ko/release_notes_v1.0.0.txt)
# RELEASE_NOTES="JLPTDeck v1.0.0 베타. 첫 시도 정답률 + 회복 분리 표시."

# Optional — export method. Default ad-hoc. Use `app-store` for TestFlight uploads.
# EXPORT_METHOD=ad-hoc
